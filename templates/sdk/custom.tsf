/** @fragment-contract
 * @description SDK Custom Method
 * @input {string} verb
 * @input {string} url
 * @input {string} endpointPath
 */
import { fragment } from '@nexical/generator';

declare const verb: string;
declare const url: string;
declare const endpointPath: string;
declare const dataArg: string;

export default fragment/* ts */`
return this._request('${verb}', \`${endpointPath}${url}\`${dataArg});
`;
